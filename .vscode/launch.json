{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run GitHub-Aware-RAG Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/extension"
      ],
      "outFiles": [
        "${workspaceFolder}/extension/dist/**/*.js"
      ],
      "preLaunchTask": "github-rag: build extension"
    }
  ]
}
