{
    "name": "github-rag",
    "displayName": "GitHub RAG",
    "description": "Semantic code reference search across your GitHub repos and starred repos",
    "version": "0.0.1",
    "publisher": "github-rag",
    "keywords": [
        "rag",
        "github",
        "semantic-search",
        "code-search",
        "vscode-extension",
        "chromadb",
        "openai"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/tungalag/Github-aware-RAG.git"
    },
    "bugs": {
        "url": "https://github.com/tungalag/Github-aware-RAG/issues"
    },
    "homepage": "https://github.com/tungalag/Github-aware-RAG#readme",
    "icon": "resources/icon.png",
    "license": "MIT",
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Other"
    ],
    "main": "./dist/extension.js",
    "activationEvents": [],
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "github-rag",
                    "title": "GitHub RAG",
                    "icon": "resources/icon.svg"
                }
            ]
        },
        "views": {
            "github-rag": [
                {
                    "type": "webview",
                    "id": "githubRag.searchView",
                    "name": "Search"
                }
            ]
        },
        "commands": [
            {
                "command": "github-rag.openPanel",
                "title": "GitHub RAG: Open Search Panel"
            },
            {
                "command": "github-rag.reindex",
                "title": "GitHub RAG: Re-index Current Repo"
            },
            {
                "command": "github-rag.setOpenAIApiKey",
                "title": "GitHub RAG: Set OpenAI API Key"
            },
            {
                "command": "github-rag.clearOpenAIApiKey",
                "title": "GitHub RAG: Clear OpenAI API Key"
            }
        ],
        "configuration": {
            "title": "GitHub RAG",
            "properties": {
                "github-rag.openaiApiKey": {
                    "type": "string",
                    "default": "",
                    "description": "Legacy fallback only. Prefer Command Palette → GitHub RAG: Set OpenAI API Key (stored in VS Code SecretStorage).",
                    "order": 1
                },
                "github-rag.pythonPath": {
                    "type": "string",
                    "default": ".venv/bin/python",
                    "description": "Path to the Python interpreter used to run the backend server",
                    "order": 2
                },
                "github-rag.backendPort": {
                    "type": "number",
                    "default": 8747,
                    "description": "Port for the local FastAPI backend server",
                    "order": 3
                }
            }
        }
    },
    "scripts": {
        "sync:backend": "node scripts/sync-backend.mjs",
        "release:prepare": "node scripts/release-prepare.mjs",
        "compile": "npm run sync:backend && node esbuild.js",
        "watch": "node esbuild.js --watch",
        "package": "npm run sync:backend && node esbuild.js --production",
        "vsix": "npm run package && npx @vscode/vsce package --allow-missing-repository",
        "vscode:prepublish": "npm run package",
        "lint": "tsc --noEmit"
    },
    "devDependencies": {
        "@vscode/vsce": "^3.6.2",
        "@types/node": "^20.11.0",
        "@types/react": "^18.2.48",
        "@types/react-dom": "^18.2.18",
        "@types/vscode": "^1.85.0",
        "esbuild": "^0.20.0",
        "typescript": "^5.3.3"
    },
    "dependencies": {
        "react": "^18.2.0",
        "react-dom": "^18.2.0"
    }
}
